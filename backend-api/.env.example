NODE_ENV=development
PORT=5001

# Local:
# MONGODB_URI=mongodb://127.0.0.1:27017/insurance_platform
# Atlas (paste from Connect → Drivers; replace <password>):
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER_HOST/insurance_platform?retryWrites=true&w=majority
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=2h

FRONTEND_URL=http://localhost:3000

# TLS for Express HTTPS — use PEM key + cert (recommended for dev):
HTTPS_KEY_PATH=./cert/server.key
HTTPS_CERT_PATH=./cert/server.crt
# Or PKCS#12 instead of the two lines above:
# HTTPS_PFX_PATH=./cert/server.pfx
# HTTPS_PFX_PASSPHRASE=replace_with_pfx_password

# Optional Keycloak SSO (see routes under /api/auth/keycloak)
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=insurance-platform
KEYCLOAK_CLIENT_ID=backend-api
KEYCLOAK_CLIENT_SECRET=xxxxxxxxxxxxxxxx
KEYCLOAK_BACKEND_CALLBACK_URL=https://localhost:5001/api/auth/keycloak/callback
KEYCLOAK_FRONTEND_SUCCESS_REDIRECT_URL=http://localhost:3000/dashboard
KEYCLOAK_FRONTEND_FAILURE_REDIRECT_URL=http://localhost:3000/login?error=keycloak
